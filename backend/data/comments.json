  },
  {
    "id": 17,
    "post_id": 4,
    "user_id": 5,
    "text": "Куда именно пойдём? В горы или на озеро?",
    "created_at": "2026-02-19T15:30:00.000Z"
  },
  {
    "id": 18,
    "post_id": 4,
    "user_id": 6,
    "text": "Палатки дадут или свои брать?",
