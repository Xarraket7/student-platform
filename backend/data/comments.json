  },
  {
    "id": 15,
    "post_id": 3,
    "user_id": 8,
    "text": "Форму спортивную нужно свою приносить?",
    "created_at": "2026-02-21T16:00:00.000Z"
  },
  {
    "id": 16,
    "post_id": 4,
    "user_id": 3,
    "text": "Я уже зарегистрировался! Кто ещё идёт?",
