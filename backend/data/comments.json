    "user_id": 8,
    "text": "Можно подать заявку по экологии?",
    "created_at": "2026-02-23T14:00:00.000Z"
  },
  {
    "id": 69,
    "post_id": 15,
    "user_id": 5,
    "text": "Будут ли приглашённые эксперты?",
